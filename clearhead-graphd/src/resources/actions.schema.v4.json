{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clearhead.us/vocab/actions/v4/actions.schema.json",
  "title": "Actions Vocabulary v4.3.0 (Ontology-Out)",
  "type": "object",
  "properties": {
    "@context": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        }
      ]
    },
    "@graph": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "required": [
    "@context",
    "@graph"
  ],
  "additionalProperties": true,
  "$defs": {
    "node": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "Plan",
            "Action",
            "Objective",
            "Charter",
            "Context",
            "ContextType"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "uuid": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "inServiceOf": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "requiresContext": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "actions": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "subCharters": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "NotStarted",
            "InProgress",
            "Completed",
            "Blocked",
            "Cancelled"
          ]
        },
        "partOf": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "isSuccessorOf": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "priority": {
          "type": "integer"
        },
        "sequentialChildren": {
          "type": "boolean"
        },
        "recurrence": {
          "type": "string"
        },
        "dueRecurrence": {
          "type": "string"
        },
        "durationMinutes": {
          "type": "integer"
        },
        "scheduledAt": {
          "type": "string",
          "format": "date-time"
        },
        "dueDate": {
          "type": "string",
          "format": "date-time"
        },
        "completedDate": {
          "type": "string",
          "format": "date-time"
        },
        "createdDate": {
          "type": "string",
          "format": "date-time"
        },
        "externalScheduleId": {
          "type": "string"
        },
        "externalOccurrenceKey": {
          "type": "string"
        },
        "contextType": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "contextIdentifier": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_@-]+$"
        },
        "contextBroader": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "contextNarrower": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      },
      "required": [
        "id",
        "type"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "Action"
              }
            }
          },
          "then": {
            "required": [
              "status"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "Context"
              }
            }
          },
          "then": {
            "required": [
              "contextIdentifier"
            ]
          }
        }
      ]
    }
  }
}
