	<https://www.commoncoreontologies.org/ont00001868> <https://clearhead.us/vocab/actions/v4#Completed> .
<urn:uuid:019f0bc9-8946-70cb-a08f-74ce8be6f2b4> a <https://clearhead.us/vocab/actions/v4#Action> ;
	<https://clearhead.us/vocab/actions/v4#hasUUID> "019f0bc9-8946-70cb-a08f-74ce8be6f2b4" ;
	<http://www.w3.org/2000/01/rdf-schema#label> "make save_domain_model set-atomic" ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "staged-temps + ordered renames + directory fsync + a .pending journal replayed on startup — recoverable-durability, not true atomicity; partial failure leaves pre-batch or full post-batch, never torn" .
