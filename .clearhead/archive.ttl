	<https://clearhead.us/vocab/actions/v4#hasUUID> "019db111-0006-7000-0000-000000000001" ;
	a <https://clearhead.us/vocab/actions/v4#Action> .
<urn:uuid:019db111-0005-7000-0000-000000000001> <https://clearhead.us/vocab/actions/v4#hasCompletedDateTime> "2026-04-21T13:40:00-07:00"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
	<https://www.commoncoreontologies.org/ont00001868> <https://clearhead.us/vocab/actions/v4#Completed> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "read and mutation policies are centralized in commands/mod.rs helpers and now reused by plan, act, service, and file command paths. mutation paths block writes on parse failure." ;
	<http://www.w3.org/2000/01/rdf-schema#label> "create CLI parse policy boundary for command handlers" ;
	<https://clearhead.us/vocab/actions/v4#hasUUID> "019db111-0005-7000-0000-000000000001" ;
	a <https://clearhead.us/vocab/actions/v4#Action> .
