	<https://www.commoncoreontologies.org/ont00001868> <https://clearhead.us/vocab/actions/v4#Completed> ;
	<http://purl.obolibrary.org/obo/BFO_0000050> <urn:uuid:019db111-0010-7000-0000-000000000001> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "parse_failed, parse_recovered, and mutation_skipped_due_to_parse telemetry events are now part of the shared schema." ;
	<http://www.w3.org/2000/01/rdf-schema#label> "add telemetry event variants for parse outcomes" ;
