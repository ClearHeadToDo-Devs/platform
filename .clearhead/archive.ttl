	<http://www.w3.org/2000/01/rdf-schema#comment> "strict/recover modes plus shared outcome payload (diagnostics + recovery metadata) are now exposed through the core parser seam." ;
	<http://www.w3.org/2000/01/rdf-schema#label> "add ParseMode and ParseOutcome types" ;
	<https://clearhead.us/vocab/actions/v4#hasUUID> "019db111-0002-7000-0000-000000000001" ;
	a <https://clearhead.us/vocab/actions/v4#Action> .
<urn:uuid:019db111-0001-7000-0000-000000000001> <https://clearhead.us/vocab/actions/v4#hasCompletedDateTime> "2026-04-21T13:40:00-07:00"^^<http://www.w3.org/2001/XMLSchema#dateTime> ;
	<https://www.commoncoreontologies.org/ont00001868> <https://clearhead.us/vocab/actions/v4#Completed> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "explicit parse mode + outcome model landed in clearhead-core; syntax errors are systemic failures for mutation boundaries while lint remains advisory. legacy parse entry points remain available as wrappers over the new contract." ;
	<http://www.w3.org/2000/01/rdf-schema#label> "define parse boundary contract in core" ;
	<https://clearhead.us/vocab/actions/v4#hasUUID> "019db111-0001-7000-0000-000000000001" ;
