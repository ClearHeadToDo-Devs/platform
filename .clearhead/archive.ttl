	<https://clearhead.us/vocab/actions/v4#hasSequentialChildren> true ;
	<http://www.w3.org/2000/01/rdf-schema#label> "establish write durability layer" ;
	<https://clearhead.us/vocab/actions/v4#hasUUID> "019f0bc9-8931-7b05-a1be-0cc39ed83d20" ;
