<urn:uuid:019f268f-eb43-7994-8d0f-13c024980696> a <https://clearhead.us/vocab/actions/v4#Action> ;
	<https://clearhead.us/vocab/actions/v4#hasUUID> "019f268f-eb43-7994-8d0f-13c024980696" ;
	<http://www.w3.org/2000/01/rdf-schema#label> "sweep dead code and single-consumer compat shims" ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "nothing links these crates except the CLI binary itself — the nvim plugin shells out — so backward-compat layers are pure carrying cost" ;
	<https://clearhead.us/vocab/actions/v4#hasPriority> 2 ;
	<https://clearhead.us/vocab/actions/v4#requiresContext> <urn:context:cli> ;
