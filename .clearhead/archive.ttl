	<http://purl.obolibrary.org/obo/BFO_0000050> <urn:uuid:019db111-0010-7000-0000-000000000001> ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "helper-level emission now includes command + source context so all adopted command paths share observability behavior." ;
	<http://www.w3.org/2000/01/rdf-schema#label> "emit parse telemetry in CLI boundary helpers" ;
